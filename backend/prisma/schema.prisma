generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MAYOR
  MINISTER
  PM
}

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  role         Role   @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
