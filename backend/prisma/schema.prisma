generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  PENDING_APPROVAL
  ACTIVE
  AWAITING_REVIEW
  COMPLETED
}

enum Role {
  CITIZEN
  MAYOR
  MINISTER
  PM
  ADMIN
}

enum ElectionType {
  ROOM
  DEPARTMENT
}

enum ElectionStatus {
  ACTIVE
  COMPLETED
  TIE_BREAKING
}

model User {
  id       String @id @default(uuid())
  username String @unique
  email    String @unique
  password String

  role             Role    @default(CITIZEN)
  refreshTokenHash String?

  socialScore Int     @default(50)
  credits     Int     @default(100)
  isJailed    Boolean @default(false)

  // one user belongs to one room
  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Restrict)

  createdAt                    DateTime         @default(now())
  updatedAt                    DateTime         @updatedAt
  createdTasks                 Task[]           @relation("TaskCreatedBy")
  assignedTasks                Task[]           @relation("TaskAssignedTo")
  mayorOfRooms                 Room[]           @relation("RoomMayor")
  primeMinisterOfDepartments   Department[]     @relation("DepartmentPrimeMinister")
  foreignMinisterOfDepartments Department[]     @relation("DepartmentForeignMinister")
  financeMinisterOfDepartments Department[]     @relation("DepartmentFinanceMinister")
  violationsReceived           Violation[]      @relation("ViolationOffender")
  violationsIssued             Violation[]      @relation("ViolationCreatedBy")
  chatMemberships              ChatRoomMember[]
  sentMessages                 ChatMessage[]

  // Treasury relations
  treasuryTransactionsCreated TreasuryTransaction[]        @relation("TreasuryTransactionCreatedBy")
  socialScorePurchaseRequests SocialScorePurchaseRequest[] @relation("SocialScoreRequestUser")
  socialScorePurchaseOffers   SocialScorePurchaseRequest[] @relation("SocialScoreRequestOfferedBy")

  // Treaty relations
  createdTreaties         Treaty[]            @relation("TreatyCreatedBy")
  hostFmTreaties          Treaty[]            @relation("TreatyHostFM")
  treatyParticipations    TreatyParticipant[] @relation("TreatyParticipantUser")
  createdClauses          TreatyClause[]      @relation("ClauseCreatedBy")
  lockedClauses           TreatyClause[]      @relation("ClauseLockedBy")
  exchangesSelling        Exchange[]          @relation("ExchangeSeller")
  exchangesBuying         Exchange[]          @relation("ExchangeBuyer")
  breachCasesFiled        BreachCase[]        @relation("BreachCaseFiler")
  breachCasesAccused      BreachCase[]        @relation("BreachCaseAccused")
  breachCasesResolved     BreachCase[]        @relation("BreachCaseResolver")
  breachCasesRuledBy      BreachCase[]        @relation("BreachCaseRuledBy")
  breachCasesRulingTarget BreachCase[]        @relation("BreachCaseRulingTarget")

  // Inter-dept treaty relations
  treatyDeptInvites      TreatyDepartment[]  @relation("TreatyDeptInvitedBy")
  treatyDeptResponses    TreatyDepartment[]  @relation("TreatyDeptRespondedBy")
  breachVerdictsProposed BreachVerdict[]     @relation("BreachVerdictProposedBy")
  breachVerdictVotes     BreachVerdictVote[] @relation("BreachVerdictVoter")

  // Election relations
  electionsWon        Election[]          @relation("ElectionWinner")
  electionCandidacies ElectionCandidate[] @relation("ElectionCandidateUser")
  electionVotes       ElectionVote[]      @relation("ElectionVoter")

  @@index([roomId])
}

model Department {
  id   String @id @default(uuid())
  name String @unique

  treasuryCredits Int @default(1000)

  rooms     Room[]
  treaties  Treaty[]
  elections Election[] @relation("ElectionDepartment")

  primeMinisterId   String?
  primeMinister     User?   @relation("DepartmentPrimeMinister", fields: [primeMinisterId], references: [id], onDelete: SetNull)
  foreignMinisterId String?
  foreignMinister   User?   @relation("DepartmentForeignMinister", fields: [foreignMinisterId], references: [id], onDelete: SetNull)
  financeMinisterId String?
  financeMinister   User?   @relation("DepartmentFinanceMinister", fields: [financeMinisterId], references: [id], onDelete: SetNull)

  treasuryTransactions        TreasuryTransaction[]
  socialScorePurchaseRequests SocialScorePurchaseRequest[]

  // Inter-dept treaty relations
  treatyDepartments  TreatyDepartment[]
  breachVerdictVotes BreachVerdictVote[] @relation("BreachVerdictVoterDept")

  // Senate chat
  senateChatRoom ChatRoom? @relation("DepartmentSenateChatRoom")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([primeMinisterId])
  @@index([foreignMinisterId])
  @@index([financeMinisterId])
}

model Room {
  id           String @id @default(uuid())
  roomNumber   String
  departmentId String

  treasuryCredits Int @default(0)

  department Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  users      User[]
  mayorId    String?
  mayor      User?      @relation("RoomMayor", fields: [mayorId], references: [id], onDelete: SetNull)

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  tasks                Task[]
  violations           Violation[]
  chatRoom             ChatRoom?
  treatyParticipations TreatyParticipant[]   @relation("TreatyParticipantRoom")
  treasuryTransactions TreasuryTransaction[]
  elections            Election[]            @relation("ElectionRoom")

  @@unique([departmentId, roomNumber])
  @@index([departmentId])
  @@index([mayorId])
}

model Task {
  id          String  @id @default(uuid())
  title       String
  description String?

  status TaskStatus @default(PENDING_APPROVAL)

  fundAmount Int @default(0)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Restrict)

  createdById String
  createdBy   User   @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  // NEW: completion + review fields
  completionSummary String?
  completedAt       DateTime?

  mayorReviewNote String?
  reviewedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  treasuryTransactions TreasuryTransaction[]

  @@index([roomId])
  @@index([createdById])
  @@index([assignedToId])
  @@index([status])
}

enum ChatRoomType {
  ROOM
  VIOLATION_CASE
  TREATY_GROUP
  BREACH_CASE
  SENATE
}

enum ViolationStatus {
  ACTIVE
  APPEALED
  IN_EVALUATION
  CLOSED_UPHELD
  CLOSED_OVERTURNED
  EXPIRED
}

enum ViolationVerdict {
  UPHELD
  OVERTURNED
  PUNISH_MAYOR
}

model ChatRoom {
  id   String       @id @default(uuid())
  type ChatRoomType @default(ROOM)

  /// ROOM chat: exactly one ChatRoom per Room
  roomId String? @unique
  room   Room?   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  /// VIOLATION_CASE chat: exactly one ChatRoom per Violation
  violationId String?    @unique
  violation   Violation? @relation(fields: [violationId], references: [id], onDelete: Cascade)

  /// TREATY_GROUP chat: exactly one ChatRoom per Treaty
  treatyId String? @unique
  treaty   Treaty? @relation(fields: [treatyId], references: [id], onDelete: Cascade)

  /// BREACH_CASE chat: exactly one ChatRoom per BreachCase
  breachCaseId String?     @unique
  breachCase   BreachCase? @relation(fields: [breachCaseId], references: [id], onDelete: Cascade)

  /// SENATE chat: one per Department
  departmentSenateId String?     @unique
  departmentSenate   Department? @relation("DepartmentSenateChatRoom", fields: [departmentSenateId], references: [id], onDelete: Cascade)

  /// When set, the chat is locked (no new messages)
  closedAt DateTime?

  members  ChatRoomMember[]
  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

model ChatRoomMember {
  id         String @id @default(uuid())
  chatRoomId String
  userId     String

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Optional moderation features for later
  mutedUntil DateTime?

  joinedAt DateTime @default(now())

  @@unique([chatRoomId, userId])
  @@index([userId])
  @@index([chatRoomId])
}

model ChatMessage {
  id         String @id @default(uuid())
  chatRoomId String
  senderId   String

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation(fields: [senderId], references: [id], onDelete: Restrict)

  content   String
  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@index([chatRoomId, createdAt])
  @@index([senderId])
}

enum ViolationPenaltyMode {
  BOTH_MANDATORY
  EITHER_CHOICE
}

enum ViolationOffenderChoice {
  CREDITS
  SOCIAL_SCORE
}

model Violation {
  id String @id @default(uuid())

  status ViolationStatus @default(ACTIVE)

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Restrict)

  offenderId String
  offender   User   @relation("ViolationOffender", fields: [offenderId], references: [id], onDelete: Restrict)

  createdById String
  createdBy   User   @relation("ViolationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  title       String
  description String?
  points      Int

  /// Credit fine amount (for penalty mode support)
  creditFine      Int                      @default(0)
  /// Penalty mode: both mandatory or offender chooses
  penaltyMode     ViolationPenaltyMode     @default(BOTH_MANDATORY)
  /// Offender's choice when EITHER_CHOICE mode
  offenderChoice  ViolationOffenderChoice?
  /// Actual deductions applied (for accurate refunding)
  creditsDeducted Int                      @default(0)
  pointsDeducted  Int                      @default(0)
  creditsRefunded Int                      @default(0)

  /// Optional expiry for minor violations
  expiresAt      DateTime?
  /// Set when the expiry job archives/expires the violation
  archivedAt     DateTime?
  /// Points refunded (set once, idempotent). 0 if no refund.
  pointsRefunded Int       @default(0)
  refundedAt     DateTime?

  /// Appeal
  appealedAt DateTime?
  appealNote String?

  /// Evaluation
  evaluationStartedAt DateTime?
  evaluationClosedAt  DateTime?

  /// Case chat room (created on start-evaluation)
  chatRoom ChatRoom?

  /// Verdict (set on close-evaluation)
  verdict     ViolationVerdict?
  verdictNote String?
  closedById  String?

  /// If verdict = PUNISH_MAYOR, this links to the new violation created against the mayor
  mayorViolationId String?

  /// Treasury transactions linked to this violation
  treasuryTransactions TreasuryTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId, createdAt])
  @@index([offenderId, createdAt])
  @@index([createdById])
  @@index([status])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════════════════════════
// TREASURY & FINANCE FEATURE
// ═══════════════════════════════════════════════════════════════

enum TreasuryTransactionType {
  DEPT_ALLOCATE_TO_ROOM
  DEPT_RECALL_FROM_ROOM
  ROOM_TASK_SPEND
  USER_BUY_SOCIAL_SCORE
  BREACH_COMPENSATION
  BREACH_FINE_INCOME
  VIOLATION_FINE_INCOME
  VIOLATION_REFUND
}

model TreasuryTransaction {
  id String @id @default(uuid())

  type   TreasuryTransactionType
  amount Int

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id], onDelete: SetNull)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  breachCaseId String?
  breachCase   BreachCase? @relation(fields: [breachCaseId], references: [id], onDelete: SetNull)

  violationId String?
  violation   Violation? @relation(fields: [violationId], references: [id], onDelete: SetNull)

  userId String?

  createdById String
  createdBy   User   @relation("TreasuryTransactionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  note String?

  createdAt DateTime @default(now())

  @@index([departmentId, createdAt])
  @@index([roomId, createdAt])
  @@index([type, createdAt])
  @@index([createdById])
  @@index([breachCaseId])
  @@index([violationId])
}

enum SocialScorePurchaseStatus {
  REQUESTED
  OFFERED
  ACCEPTED
  REJECTED
  CANCELLED
}

model SocialScorePurchaseRequest {
  id String @id @default(uuid())

  userId String
  user   User   @relation("SocialScoreRequestUser", fields: [userId], references: [id], onDelete: Restrict)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  status      SocialScorePurchaseStatus @default(REQUESTED)
  requestNote String?

  /// Offer fields (set by PM)
  offeredById         String?
  offeredBy           User?     @relation("SocialScoreRequestOfferedBy", fields: [offeredById], references: [id], onDelete: SetNull)
  offeredPriceCredits Int?
  offeredSocialScore  Int?
  offeredAt           DateTime?
  respondedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([departmentId])
  @@index([userId])
}

// ═══════════════════════════════════════════════════════════════
// TREATY FEATURE
// ═══════════════════════════════════════════════════════════════

enum TreatyMode {
  DEPT_SCOPE
  INTER_DEPT
}

enum TreatyStatus {
  NEGOTIATION
  LOCKED
  ACTIVE
  EXPIRED
}

enum TreatyType {
  EXCHANGE
  NON_EXCHANGE
}

enum TreatyDepartmentStatus {
  PENDING
  ACCEPTED
  REJECTED
  LEFT
}

enum BreachVerdictStatus {
  PROPOSED
  ACCEPTED
  REJECTED
}

enum BreachVerdictRuling {
  ACCUSED
  ACCUSER
  NONE
}

enum BreachVerdictPenaltyMode {
  BOTH_MANDATORY
  EITHER_CHOICE
}

enum ParticipantType {
  ROOM
  USER
}

enum ParticipantStatus {
  PENDING
  ACCEPTED
  REJECTED
  LEFT
}

enum ExchangeType {
  TASK_FOR_BOUNTY
  NOTES_OR_RESOURCES_FOR_BOUNTY
  ITEMS_FOR_BOUNTY
}

enum ExchangeStatus {
  OPEN
  ACCEPTED
  DELIVERED
  APPROVED
  REJECTED
}

enum BreachCaseStatus {
  OPEN
  IN_REVIEW
  AWAITING_CRIMINAL_CHOICE
  RESOLVED
}

enum BreachRulingType {
  AGAINST_ACCUSED
  AGAINST_ACCUSER
  NONE
}

enum BreachPenaltyMode {
  BOTH_MANDATORY
  EITHER_CHOICE
  NONE
}

enum BreachCriminalChoice {
  SOCIAL
  CREDITS
}

model Treaty {
  id String @id @default(uuid())

  title  String
  type   TreatyType   @default(NON_EXCHANGE)
  status TreatyStatus @default(NEGOTIATION)
  mode   TreatyMode   @default(DEPT_SCOPE)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  createdById String
  createdBy   User   @relation("TreatyCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  /// Host foreign minister (for INTER_DEPT treaties)
  hostForeignMinisterId String?
  hostForeignMinister   User?   @relation("TreatyHostFM", fields: [hostForeignMinisterId], references: [id], onDelete: SetNull)

  /// Treaty must have a finite end date
  endsAt DateTime

  chatRoom          ChatRoom?
  participants      TreatyParticipant[]
  clauses           TreatyClause[]
  exchanges         Exchange[]
  breachCases       BreachCase[]
  treatyDepartments TreatyDepartment[]
  breachVerdicts    BreachVerdict[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([createdById])
  @@index([status])
  @@index([mode])
}

model TreatyClause {
  id String @id @default(uuid())

  treatyId String
  treaty   Treaty @relation(fields: [treatyId], references: [id], onDelete: Cascade)

  content    String
  orderIndex Int    @default(0)

  createdById String
  createdBy   User   @relation("ClauseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  /// Clause locking (inter-dept treaties)
  isLocked   Boolean   @default(false)
  lockedById String?
  lockedBy   User?     @relation("ClauseLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)
  lockedAt   DateTime?

  breachCases BreachCaseClause[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treatyId, orderIndex])
}

model TreatyParticipant {
  id String @id @default(uuid())

  treatyId String
  treaty   Treaty @relation(fields: [treatyId], references: [id], onDelete: Cascade)

  type   ParticipantType
  status ParticipantStatus @default(PENDING)

  /// For ROOM participants
  roomId String?
  room   Room?   @relation("TreatyParticipantRoom", fields: [roomId], references: [id], onDelete: Cascade)

  /// For USER participants
  userId String?
  user   User?   @relation("TreatyParticipantUser", fields: [userId], references: [id], onDelete: Cascade)

  respondedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([treatyId, roomId])
  @@unique([treatyId, userId])
  @@index([treatyId])
}

model Exchange {
  id String @id @default(uuid())

  treatyId String
  treaty   Treaty @relation(fields: [treatyId], references: [id], onDelete: Cascade)

  type   ExchangeType
  status ExchangeStatus @default(OPEN)

  title       String
  description String?
  bounty      Int

  sellerId String?
  seller   User?   @relation("ExchangeSeller", fields: [sellerId], references: [id], onDelete: SetNull)

  buyerId String
  buyer   User   @relation("ExchangeBuyer", fields: [buyerId], references: [id], onDelete: Restrict)

  deliveryNotes String?
  deliveredAt   DateTime?
  reviewedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([treatyId])
  @@index([sellerId])
  @@index([status])
}

model BreachCase {
  id String @id @default(uuid())

  treatyId String
  treaty   Treaty @relation(fields: [treatyId], references: [id], onDelete: Cascade)

  status BreachCaseStatus @default(OPEN)

  filerId String
  filer   User   @relation("BreachCaseFiler", fields: [filerId], references: [id], onDelete: Restrict)

  accusedUserId String
  accusedUser   User   @relation("BreachCaseAccused", fields: [accusedUserId], references: [id], onDelete: Restrict)

  title       String
  description String?

  /// Optional reference to a specific exchange
  exchangeId String?

  clauses BreachCaseClause[]

  /// Case chat (created when evaluation starts)
  chatRoom ChatRoom?

  /// Evaluation
  evaluatedAt DateTime?

  /// Ruling (PM only)
  ruledAt            DateTime?
  ruledById          String?
  ruledBy            User?                 @relation("BreachCaseRuledBy", fields: [ruledById], references: [id], onDelete: SetNull)
  rulingType         BreachRulingType?
  rulingTargetUserId String?
  rulingTarget       User?                 @relation("BreachCaseRulingTarget", fields: [rulingTargetUserId], references: [id], onDelete: SetNull)
  penaltyMode        BreachPenaltyMode?
  socialPenalty      Int?
  creditFine         Int?
  criminalChoice     BreachCriminalChoice?

  /// Resolution
  resolutionNote String?
  resolvedById   String?
  resolvedBy     User?     @relation("BreachCaseResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  resolvedAt     DateTime?

  /// Treasury transactions linked to this breach case
  treasuryTransactions TreasuryTransaction[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  breachVerdicts BreachVerdict[]

  @@index([treatyId])
  @@index([accusedUserId])
  @@index([status])
}

model BreachCaseClause {
  id String @id @default(uuid())

  breachCaseId String
  breachCase   BreachCase @relation(fields: [breachCaseId], references: [id], onDelete: Cascade)

  clauseId String
  clause   TreatyClause @relation(fields: [clauseId], references: [id], onDelete: Cascade)

  @@unique([breachCaseId, clauseId])
}

// ═══════════════════════════════════════════════════════════════
// INTER-DEPT TREATY MODELS
// ═══════════════════════════════════════════════════════════════

model TreatyDepartment {
  id String @id @default(uuid())

  treatyId String
  treaty   Treaty @relation(fields: [treatyId], references: [id], onDelete: Cascade)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)

  status TreatyDepartmentStatus @default(PENDING)

  invitedById String
  invitedBy   User   @relation("TreatyDeptInvitedBy", fields: [invitedById], references: [id], onDelete: Restrict)

  respondedById String?
  respondedBy   User?   @relation("TreatyDeptRespondedBy", fields: [respondedById], references: [id], onDelete: SetNull)

  respondedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([treatyId, departmentId])
  @@index([treatyId])
  @@index([departmentId])
  @@index([status])
}

model BreachVerdict {
  id String @id @default(uuid())

  breachCaseId String
  breachCase   BreachCase @relation(fields: [breachCaseId], references: [id], onDelete: Cascade)

  treatyId String
  treaty   Treaty @relation(fields: [treatyId], references: [id], onDelete: Cascade)

  proposedById String
  proposedBy   User   @relation("BreachVerdictProposedBy", fields: [proposedById], references: [id], onDelete: Restrict)

  status        BreachVerdictStatus      @default(PROPOSED)
  ruledAgainst  BreachVerdictRuling      @default(NONE)
  creditFine    Int                      @default(0)
  socialPenalty Int                      @default(0)
  penaltyMode   BreachVerdictPenaltyMode @default(BOTH_MANDATORY)
  notes         String?

  votes BreachVerdictVote[]

  createdAt   DateTime  @default(now())
  finalizedAt DateTime?

  @@index([breachCaseId])
  @@index([treatyId])
  @@index([status])
}

model BreachVerdictVote {
  id String @id @default(uuid())

  verdictId String
  verdict   BreachVerdict @relation(fields: [verdictId], references: [id], onDelete: Cascade)

  voterUserId String
  voterUser   User   @relation("BreachVerdictVoter", fields: [voterUserId], references: [id], onDelete: Restrict)

  voterDepartmentId String
  voterDepartment   Department @relation("BreachVerdictVoterDept", fields: [voterDepartmentId], references: [id], onDelete: Restrict)

  vote    String // ACCEPT or REJECT
  comment String?

  createdAt DateTime @default(now())

  @@unique([verdictId, voterUserId])
  @@index([verdictId])
  @@index([voterDepartmentId])
}

// ═══════════════════════════════════════════════════════════════
// ELECTION FEATURE
// ═══════════════════════════════════════════════════════════════

model Election {
  id     String         @id @default(uuid())
  type   ElectionType
  status ElectionStatus @default(ACTIVE)

  // For ROOM elections
  roomId String?
  room   Room?   @relation("ElectionRoom", fields: [roomId], references: [id], onDelete: Cascade)

  // For DEPARTMENT elections
  departmentId String?
  department   Department? @relation("ElectionDepartment", fields: [departmentId], references: [id], onDelete: Cascade)

  deadline DateTime

  // The elected winner
  winnerId String?
  winner   User?   @relation("ElectionWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  candidates ElectionCandidate[]
  votes      ElectionVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
  @@index([departmentId])
  @@index([status])
}

model ElectionCandidate {
  id         String   @id @default(uuid())
  electionId String
  election   Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("ElectionCandidateUser", fields: [userId], references: [id], onDelete: Cascade)

  totalVotePower Int @default(0)

  votes ElectionVote[]

  @@unique([electionId, userId])
  @@index([electionId])
}

model ElectionVote {
  id         String   @id @default(uuid())
  electionId String
  election   Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  voterId String
  voter   User   @relation("ElectionVoter", fields: [voterId], references: [id], onDelete: Cascade)

  candidateId String
  candidate   ElectionCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  votePower Int

  createdAt DateTime @default(now())

  @@unique([electionId, voterId])
  @@index([electionId])
  @@index([candidateId])
}
